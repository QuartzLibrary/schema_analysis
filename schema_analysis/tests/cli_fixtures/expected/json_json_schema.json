  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "age": {
      "type": "integer"
    },
    "active": {
      "type": "boolean"
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    }
  },
  "required": [
    "name",
    "age",
    "active",
    "scores"
  ]
}
