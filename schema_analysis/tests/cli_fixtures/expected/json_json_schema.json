{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "type": "object",
  "required": [
    "active",
    "age",
    "name",
    "scores"
  ],
  "properties": {
    "active": {
      "type": "boolean"
    },
    "age": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    }
  }
}
